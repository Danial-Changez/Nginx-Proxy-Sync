# Required
NPM_EMAIL=admin@example.com
NPM_PASSWORD=changeme
NPM_DOMAIN=example.com

# Optional
# NPM_DEFAULT_CERT_NAME=*.example.com
# NPM_DEFAULT_SCHEME=http
# NPM_NETWORK=myproject_proxy-net
# NPM_DELETE_ORPHANS=true
# NPM_SYNC_INTERVAL=60

# TrueNAS discovery
# TRUENAS_URL=https://192.168.1.100
# TRUENAS_API_KEY=your-api-key
# TRUENAS_SKIP_APPS=glances,node-exporter

# Pi-hole DNS sync
# PIHOLE_URL=http://192.168.1.1:8053
# PIHOLE_PASSWORD=your-pihole-password
# NPM_IP=192.168.1.50

# Static hosts file
# NPM_REMOTE_CONFIG=/config/remote-hosts.json
